# Cloudflare Pages redirects.
# Crawlers and SEO tools probe the conventional /sitemap.xml path, but
# @astrojs/sitemap only emits /sitemap-index.xml. The absolute apex rule must
# sit above the apex wildcard so those probes resolve in a single hop.
https://govhub.online/sitemap.xml  https://www.govhub.online/sitemap-index.xml  301
/sitemap.xml  /sitemap-index.xml  301

# Apex → www so the canonical host (www.govhub.online) and the served host agree.
https://govhub.online/*  https://www.govhub.online/:splat  301

# Legacy competitor slug → clean slug (site was never live, kept for safety).
/vs/deltek-govwin-iq/*            /vs/govwin-iq/:splat            301
/alternatives/deltek-govwin-iq/*  /alternatives/govwin-iq/:splat  301

# Old app deep-links (from the previous combined site) → the app subdomain,
# so bookmarks and stale links don't 404 on the marketing site. Both the bare
# and trailing-slash forms are mapped: the app subdomain links to /signup and
# /auth without a slash, and crawlers probe the /signup/ and /auth/ forms.
/auth       https://app.govhub.online/auth          301
/auth/      https://app.govhub.online/auth          301
/signup     https://app.govhub.online/signup        301
/signup/    https://app.govhub.online/signup        301
/login      https://app.govhub.online/auth          301
/login/     https://app.govhub.online/auth          301
/v2/*       https://app.govhub.online/v2/:splat      301

# Marketing slugs that changed (old Lovable site → new Astro site).
/solutions/proposal-generator   /solutions/ai-proposal-generator/     301
/solutions/technical-review     /solutions/technical-writer-review/   301
