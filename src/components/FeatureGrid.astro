---
import Icon from './Icon.astro';

interface Feature {
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  features: Feature[];
  columns?: number;
}

const { features, columns = 2 } = Astro.props;
---

<div class="feature-grid" style={`--cols:${columns}`}>
  {features.map((f) => (
    <article>
      {f.icon && <Icon name={f.icon} size={28} class="feature-icon" />}
      <h3>{f.title}</h3>
      <p>{f.description}</p>
    </article>
  ))}
</div>

<style>
  .feature-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    margin: 2rem 0;
  }
  article {
    background: var(--bg-elevated);
    border: 1.5px solid var(--border);
    border-radius: var(--gh-radius-md);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    transition: transform var(--gh-dur-med) var(--gh-ease), box-shadow var(--gh-dur-med) var(--gh-ease);
  }
  article:hover {
    transform: translateY(-3px);
    box-shadow: var(--gh-shadow-raised);
  }
  article :global(.feature-icon) {
    margin-bottom: 0.75rem;
  }
  h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    color: var(--fg);
  }
  p {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.95rem;
  }
</style>
