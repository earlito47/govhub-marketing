---
const links = [
  { href: '/solutions/ai-proposal-generator/', label: 'Solutions' },
  { href: '/pricing/', label: 'Pricing' },
  { href: '/blog/', label: 'Blog' },
  { href: '/faq/', label: 'FAQ' },
];
---

<header class="site-header">
  <div class="container nav">
    <a href="/" class="brand">GovHub</a>
    <nav aria-label="Primary">
      <ul>
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    color: var(--fg);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
  }
  .brand:hover {
    text-decoration: none;
  }
  nav ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: var(--fg-muted);
    font-size: 0.95rem;
  }
  nav a:hover {
    color: var(--fg);
    text-decoration: none;
  }
</style>
