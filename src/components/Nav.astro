---
import { SIGNIN_URL, SIGNUP_URL } from '../config';

const links = [
  { href: '/solutions/', label: 'Solutions' },
  { href: '/pricing/', label: 'Pricing' },
  { href: '/vs/', label: 'Compare' },
  { href: '/case-studies/', label: 'Case studies' },
  { href: '/blog/', label: 'Blog' },
  { href: '/faq/', label: 'FAQ' },
];
---

<header class="site-header">
  <div class="container nav">
    <a href="/" class="brand" aria-label="GovHub home">
      <img src="/brand/logos/govhub-logo-horizontal.svg" alt="GovHub" height="28" />
    </a>
    <nav aria-label="Primary">
      <ul>
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>
    <div class="actions">
      <a class="signin" href={SIGNIN_URL}>Sign in</a>
      <a class="cta" href={SIGNUP_URL}>Start free trial</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--bg-elevated);
    padding: 0.85rem 0;
    position: sticky;
    top: 0;
    z-index: 20;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
  }
  .brand img {
    height: 28px;
    width: auto;
    display: block;
  }
  nav {
    flex: 1;
  }
  nav ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: var(--fg-muted);
    font-family: var(--gh-font-brand);
    font-size: 0.95rem;
  }
  nav a:hover {
    color: var(--gh-ink-900);
    text-decoration: none;
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .signin {
    color: var(--fg-muted);
    font-family: var(--gh-font-brand);
    font-size: 0.95rem;
  }
  .signin:hover {
    color: var(--gh-ink-900);
    text-decoration: none;
  }
  .cta {
    display: inline-block;
    padding: 0.55rem 1.25rem;
    background: var(--gh-maroon-600);
    color: #fff;
    border-radius: var(--gh-radius-pill);
    font-family: var(--gh-font-brand);
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
    transition: background var(--gh-dur-fast) var(--gh-ease), transform var(--gh-dur-fast) var(--gh-ease);
  }
  .cta:hover {
    background: var(--gh-maroon-700);
    transform: translateY(-1px);
    text-decoration: none;
  }
  @media (max-width: 760px) {
    nav {
      display: none;
    }
    .signin {
      display: none;
    }
  }
</style>
