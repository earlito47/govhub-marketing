---
import { testimonials } from '../data/testimonials';

interface Props {
  heading?: string;
}

const { heading = 'What contractors say' } = Astro.props;
---

{testimonials.length > 0 && (
  <section class="testimonials gh-section-confetti">
    <h2>{heading}</h2>
    <div class="grid">
      {testimonials.map((t) => (
        <figure>
          <blockquote>{t.quote}</blockquote>
          <figcaption>
            <span class="role">{t.role}</span>
            <span class="org">{t.orgType}</span>
            {t.metric && <span class="metric">{t.metric}</span>}
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
)}

<style>
  /* .gh-section-confetti (tokens.css) lays the nugget-confetti tile behind the quotes. */
  .testimonials {
    margin: 4rem 0;
    padding: 2rem 1.5rem;
    border-radius: var(--gh-radius-lg);
  }
  .testimonials h2 {
    margin: 0 0 1.5rem;
  }
  .grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  figure {
    margin: 0;
    background: var(--bg-elevated);
    border: 1.5px solid var(--border);
    border-left: 4px solid var(--gh-gold-400);
    border-radius: var(--gh-radius-md);
    padding: 1.5rem;
    box-shadow: var(--shadow);
  }
  blockquote {
    margin: 0 0 1rem;
    color: var(--fg);
    font-size: 1rem;
    line-height: 1.55;
  }
  figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .role {
    color: var(--fg);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .org,
  .metric {
    color: var(--fg-muted);
    font-size: 0.85rem;
  }
  .metric {
    color: var(--gh-teal-700);
    font-weight: 600;
  }
</style>
