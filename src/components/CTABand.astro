---
import { SIGNUP_URL } from '../config';

interface Props {
  heading: string;
  sub?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  heading,
  sub,
  primaryHref = SIGNUP_URL,
  primaryLabel = 'Start free trial',
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="cta-band">
  <div class="inner">
    <h2>{heading}</h2>
    {sub && <p>{sub}</p>}
    <div class="buttons">
      <a class="primary" href={primaryHref}>{primaryLabel}</a>
      {secondaryHref && secondaryLabel && (
        <a class="secondary" href={secondaryHref}>{secondaryLabel}</a>
      )}
    </div>
    <p class="trust">No credit card required · 14-day free trial</p>
  </div>
</section>

<style>
  /* Night ridge, lantern lit — the guide's CTA band on every page. */
  .cta-band {
    margin: 4rem 0 1rem;
    background: var(--gh-navy-800) url('/brand/page-graphics/cta-band-night-mountains.svg') center / cover no-repeat;
    border-radius: var(--gh-radius-lg);
    padding: 3.5rem 1.5rem;
    color: var(--gh-ink-inverse);
  }
  .inner {
    max-width: 40rem;
    margin: 0 auto;
    text-align: center;
  }
  h2 {
    margin: 0 0 0.75rem;
    color: var(--gh-ink-inverse);
  }
  p {
    color: rgba(250, 245, 236, 0.85);
    margin: 0 auto 1.5rem;
    max-width: 34rem;
  }
  .buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .primary {
    display: inline-block;
    padding: 0.75rem 1.6rem;
    background: var(--gh-maroon-600);
    color: #fff;
    border-radius: var(--gh-radius-pill);
    font-family: var(--gh-font-brand);
    font-weight: 600;
    transition: background var(--gh-dur-fast) var(--gh-ease), transform var(--gh-dur-fast) var(--gh-ease);
  }
  .primary:hover {
    background: var(--gh-maroon-700);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .secondary {
    display: inline-block;
    padding: 0.75rem 1.6rem;
    border: 2px solid var(--gh-ink-inverse);
    border-radius: var(--gh-radius-pill);
    color: var(--gh-ink-inverse);
    font-family: var(--gh-font-brand);
    font-weight: 600;
  }
  .secondary:hover {
    background: rgba(250, 245, 236, 0.12);
    text-decoration: none;
  }
  .trust {
    font-size: 0.85rem;
    color: var(--gh-ink-inverse-soft);
    margin: 1.5rem 0 0;
  }
</style>
