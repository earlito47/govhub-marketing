---
import { CONTACT_EMAIL } from '../config';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="cols">
      <div>
        <p class="brand">GovHub</p>
        <p class="muted">AI proposal writing for government contractors.</p>
      </div>
      <div>
        <p class="heading">Product</p>
        <ul>
          <li><a href="/solutions/compliance-matrix-generator/">Compliance matrix generator</a></li>
          <li><a href="/solutions/ai-proposal-generator/">AI proposal generator</a></li>
          <li><a href="/solutions/form-autofiller/">Form autofiller</a></li>
          <li><a href="/solutions/">All solutions</a></li>
          <li><a href="/pricing/">Pricing</a></li>
        </ul>
      </div>
      <div>
        <p class="heading">Compare</p>
        <ul>
          <li><a href="/vs/loopio/">GovHub vs Loopio</a></li>
          <li><a href="/vs/responsive/">GovHub vs Responsive</a></li>
          <li><a href="/vs/govwin-iq/">GovHub vs Deltek GovWin IQ</a></li>
          <li><a href="/alternatives/loopio/">Loopio alternatives</a></li>
        </ul>
      </div>
      <div>
        <p class="heading">Company</p>
        <ul>
          <li><a href="/about/">About</a></li>
          <li><a href="/security/">Security</a></li>
          <li><a href="/compliance/">Compliance</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/faq/">FAQ</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="bottom">
      <p class="copyright">© {year} GovHub. All rights reserved.</p>
      <p class="legal">
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-elevated);
    padding: 3rem 0 2rem;
    margin-top: 5rem;
  }
  .cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
    margin-bottom: 2.5rem;
  }
  .brand {
    font-weight: 700;
    color: var(--fg);
    margin: 0 0 0.5rem;
  }
  .muted {
    color: var(--fg-muted);
    font-size: 0.9rem;
    margin: 0;
  }
  .heading {
    color: var(--fg);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.75rem;
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  li {
    margin: 0.4rem 0;
  }
  li a {
    color: var(--fg-muted);
    font-size: 0.9rem;
  }
  li a:hover {
    color: var(--fg);
    text-decoration: none;
  }
  .bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .copyright,
  .legal {
    color: var(--fg-muted);
    font-size: 0.85rem;
    margin: 0;
  }
  .legal {
    display: flex;
    gap: 1.25rem;
  }
  .legal a {
    color: var(--fg-muted);
  }
  .legal a:hover {
    color: var(--fg);
    text-decoration: none;
  }
</style>
