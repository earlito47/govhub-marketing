---
import { CONTACT_EMAIL, SOCIAL_LINKS } from '../config';
const year = new Date().getFullYear();
---

<div class="gh-footer-ridge" aria-hidden="true"></div>
<footer class="site-footer">
  <div class="container">
    <div class="cols">
      <div>
        <p class="brand">
          <img src="/brand/logos/govhub-logo-horizontal-white.svg" alt="GovHub" height="26" />
        </p>
        <p class="muted">AI proposal writing for government contractors.</p>
      </div>
      <div>
        <p class="heading">Product</p>
        <ul>
          <li><a href="/solutions/compliance-matrix-generator/">Compliance matrix generator</a></li>
          <li><a href="/solutions/ai-proposal-generator/">AI proposal generator</a></li>
          <li><a href="/solutions/form-autofiller/">Form autofiller</a></li>
          <li><a href="/solutions/">All solutions</a></li>
          <li><a href="/pricing/">Pricing</a></li>
        </ul>
      </div>
      <div>
        <p class="heading">Compare</p>
        <ul>
          <li><a href="/vs/loopio/">GovHub vs Loopio</a></li>
          <li><a href="/vs/responsive/">GovHub vs Responsive</a></li>
          <li><a href="/vs/govwin-iq/">GovHub and Deltek GovWin IQ</a></li>
          <li><a href="/alternatives/loopio/">Loopio alternatives</a></li>
        </ul>
      </div>
      <div>
        <p class="heading">Company</p>
        <ul>
          <li><a href="/about/">About</a></li>
          <li><a href="/security/">Security</a></li>
          <li><a href="/compliance/">Compliance</a></li>
          <li><a href="/insights/">Federal contract data</a></li>
          <li><a href="/case-studies/">Case studies</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/faq/">FAQ</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="bottom">
      <p class="copyright">© {year} GovHub. All rights reserved.</p>
      {SOCIAL_LINKS.length > 0 && (
        <p class="social">
          {SOCIAL_LINKS.map((s) => (
            <a href={s.href} rel="me noopener" target="_blank">{s.label}</a>
          ))}
        </p>
      )}
      <p class="legal">
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      </p>
    </div>
  </div>
</footer>

<style>
  /* Teal/navy ridgeline sits flush above the navy-800 night footer. */
  .gh-footer-ridge {
    margin-top: 5rem;
  }
  .site-footer {
    background: var(--gh-navy-800);
    color: var(--gh-ink-inverse);
    padding: 3rem 0 2rem;
  }
  .cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
    margin-bottom: 2.5rem;
  }
  .brand {
    margin: 0 0 0.75rem;
  }
  .brand img {
    height: 26px;
    width: auto;
    display: block;
  }
  .muted {
    color: rgba(250, 245, 236, 0.7);
    font-size: 0.9rem;
    margin: 0;
  }
  .heading {
    color: var(--gh-ink-inverse-soft);
    font-family: var(--gh-font-brand);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.75rem;
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  li {
    margin: 0.4rem 0;
  }
  li a {
    color: rgba(250, 245, 236, 0.7);
    font-size: 0.9rem;
  }
  li a:hover {
    color: var(--gh-ink-inverse);
    text-decoration: none;
  }
  .bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(250, 245, 236, 0.15);
  }
  .copyright,
  .legal,
  .social {
    color: rgba(250, 245, 236, 0.7);
    font-size: 0.85rem;
    margin: 0;
  }
  .social {
    display: flex;
    gap: 1.25rem;
  }
  .social a {
    color: rgba(250, 245, 236, 0.7);
  }
  .legal {
    display: flex;
    gap: 1.25rem;
  }
  .legal a {
    color: rgba(250, 245, 236, 0.7);
  }
  .legal a:hover {
    color: var(--gh-ink-inverse);
    text-decoration: none;
  }
</style>
