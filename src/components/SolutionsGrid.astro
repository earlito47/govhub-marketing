---
import { solutions, featuredSolutions, type Solution } from '../data/solutions';
import Icon from './Icon.astro';

interface Props {
  /** 'featured' shows only homepage-featured solutions; 'all' shows every one. */
  mode?: 'featured' | 'all';
}

const { mode = 'all' } = Astro.props;
const items: Solution[] = mode === 'featured' ? featuredSolutions() : solutions;
---

<div class="solutions-grid">
  {items.map((s) => (
    <a class="card" href={`/solutions/${s.slug}/`}>
      {s.icon && <Icon name={s.icon} size={28} class="card-icon" />}
      <h3>{s.name}</h3>
      <p>{s.summary}</p>
      <span class="more">Learn more →</span>
    </a>
  ))}
</div>

<style>
  .solutions-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    margin: 2rem 0;
  }
  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg-elevated);
    border: 1.5px solid var(--border);
    border-radius: var(--gh-radius-md);
    padding: 1.5rem;
    color: inherit;
    box-shadow: var(--shadow);
    transition:
      border-color var(--gh-dur-fast) var(--gh-ease),
      transform var(--gh-dur-med) var(--gh-ease),
      box-shadow var(--gh-dur-med) var(--gh-ease);
  }
  .card:hover {
    border-color: var(--gh-teal-600);
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: var(--gh-shadow-raised);
  }
  .card :global(.card-icon) {
    margin-bottom: 0.75rem;
  }
  h3 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    color: var(--fg);
  }
  p {
    margin: 0 0 1rem;
    color: var(--fg-muted);
    font-size: 0.95rem;
    flex-grow: 1;
  }
  .more {
    color: var(--gh-teal-700);
    font-family: var(--gh-font-brand);
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
