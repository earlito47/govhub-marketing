---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow?: string;
  title: string;
  lede: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  trust?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  /** Brand scene from public/ (SVG preferred). Decorative (aria-hidden) unless artAlt is set. */
  art?: string;
  /** Describe the art when it carries meaning; omit to keep it decorative. */
  artAlt?: string;
  artWidth?: number;
  artHeight?: number;
}

const {
  eyebrow,
  title,
  lede,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
  trust,
  image,
  imageAlt = '',
  art,
  artAlt,
  artWidth = 900,
  artHeight = 640,
} = Astro.props;
---

<section class:list={['hero', (image || art) && 'has-image']}>
  <div class="copy">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    <p class="lede">{lede}</p>
    <div class="ctas">
      <a class="primary" href={primaryHref}>{primaryLabel}</a>
      {secondaryHref && secondaryLabel && (
        <a class="secondary" href={secondaryHref}>{secondaryLabel}</a>
      )}
    </div>
    {trust && <p class="trust">{trust}</p>}
  </div>
  {art ? (
    <div class="media art">
      <img src={art} alt={artAlt ?? ''} aria-hidden={artAlt ? undefined : 'true'} width={artWidth} height={artHeight} loading="eager" decoding="async" />
    </div>
  ) : image && (
    <div class="media">
      <Image src={image} alt={imageAlt} widths={[480, 800, 1200]} sizes="(max-width: 900px) 100vw, 40vw" loading="eager" />
    </div>
  )}
</section>

<style>
  .hero {
    padding: 3.5rem 0 3rem;
  }
  .hero.has-image {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 3rem;
    align-items: center;
  }
  /* Grid items must be allowed to shrink below the art's intrinsic width,
     or the 900px scene forces horizontal overflow on small screens. */
  .hero.has-image > * {
    min-width: 0;
  }
  .copy {
    max-width: 40rem;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 1rem;
  }
  h1 {
    font-weight: 700;
    margin: 0 0 1.25rem;
  }
  .lede {
    font-size: 1.2rem;
    color: var(--fg-muted);
    margin: 0 0 2rem;
  }
  .ctas {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .primary {
    display: inline-block;
    padding: 0.8rem 1.6rem;
    background: var(--gh-maroon-600);
    color: #fff;
    border-radius: var(--gh-radius-pill);
    font-family: var(--gh-font-brand);
    font-weight: 600;
    transition: background var(--gh-dur-fast) var(--gh-ease), transform var(--gh-dur-fast) var(--gh-ease);
  }
  .primary:hover {
    background: var(--gh-maroon-700);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .secondary {
    display: inline-block;
    padding: 0.8rem 1.25rem;
    color: var(--gh-teal-700);
    font-family: var(--gh-font-brand);
    font-weight: 600;
  }
  .trust {
    font-size: 0.85rem;
    color: var(--fg-muted);
    margin: 1.5rem 0 0;
  }
  .media :global(img) {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  /* Scene art is flat brand illustration — no photo chrome. */
  .media.art :global(img) {
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }
  @media (max-width: 900px) {
    .hero.has-image {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    /* Guide: scene art stacks ABOVE the H1 on mobile (photos stay below). */
    .media.art {
      order: -1;
      max-width: 26rem;
      margin: 0 auto;
    }
    /* Center the hero on small screens to match the centered stacked art. */
    .copy {
      margin: 0 auto;
      text-align: center;
    }
    .ctas {
      justify-content: center;
    }
  }
</style>
