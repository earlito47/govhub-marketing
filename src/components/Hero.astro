---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { APP_URL } from '../config';

interface Props {
  eyebrow?: string;
  title: string;
  lede: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  trust?: string;
  /** Render the ChatGPT-style intake box in place of the CTA buttons (home only). */
  intake?: boolean;
  image?: ImageMetadata;
  imageAlt?: string;
  /** Brand scene from public/ (SVG preferred). Decorative (aria-hidden) unless artAlt is set. */
  art?: string;
  /** Describe the art when it carries meaning; omit to keep it decorative. */
  artAlt?: string;
  artWidth?: number;
  artHeight?: number;
}

const {
  eyebrow,
  title,
  lede,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
  trust,
  intake = false,
  image,
  imageAlt = '',
  art,
  artAlt,
  artWidth = 900,
  artHeight = 640,
} = Astro.props;
---

<section class:list={['hero', (image || art) && 'has-image']}>
  <div class="copy">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    <p class="lede">{lede}</p>
    {intake ? (
      <div class="intake">
        <textarea
          id="hero-intake-text"
          class="intake-text"
          rows="3"
          placeholder="Paste your RFP here, or describe what you need. You'll attach the solicitation and any files on the next step."
        ></textarea>
        <div class="intake-row">
          <span class="intake-hint">PDF, Word, Excel, or ZIP — attached on the next step</span>
          <button type="button" id="hero-intake-go" class="primary intake-go">Analyze my RFP</button>
        </div>
      </div>
    ) : (
      <div class="ctas">
        <a class="primary" href={primaryHref}>{primaryLabel}</a>
        {secondaryHref && secondaryLabel && (
          <a class="secondary" href={secondaryHref}>{secondaryLabel}</a>
        )}
      </div>
    )}
    {trust && <p class="trust">{trust}</p>}
  </div>
  {art ? (
    <div class="media art">
      <img src={art} alt={artAlt ?? ''} aria-hidden={artAlt ? undefined : 'true'} width={artWidth} height={artHeight} loading="eager" decoding="async" />
    </div>
  ) : image && (
    <div class="media">
      <Image src={image} alt={imageAlt} widths={[480, 800, 1200]} sizes="(max-width: 900px) 100vw, 40vw" loading="eager" />
    </div>
  )}
</section>

<!-- Intake hand-off. Top-level (Astro hoists <script> at build time); the
     null-guards make it a no-op on hero variants without the intake box. -->
<script define:vars={{ appUrl: APP_URL }}>
  // Hand the pasted text off to the app's /start intake. Short text rides a
  // query param; long text / files are entered on the app origin (browser
  // storage is origin-scoped, so a static page can't carry them across the
  // subdomain). The app then decides signed-in → workspace vs signup+replay.
  const btn = document.getElementById('hero-intake-go');
  const ta = document.getElementById('hero-intake-text');
  if (btn && ta) {
    const go = () => {
      const text = (ta.value || '').trim();
      const base = appUrl + '/start';
      const url = text && text.length <= 1500 ? base + '?text=' + encodeURIComponent(text) : base;
      window.location.href = url;
    };
    btn.addEventListener('click', go);
    ta.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') { e.preventDefault(); go(); }
    });
  }
</script>

<style>
  .hero {
    padding: 3.5rem 0 3rem;
  }
  .hero.has-image {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 3rem;
    align-items: center;
  }
  /* Grid items must be allowed to shrink below the art's intrinsic width,
     or the 900px scene forces horizontal overflow on small screens. */
  .hero.has-image > * {
    min-width: 0;
  }
  .copy {
    max-width: 40rem;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 1rem;
  }
  h1 {
    font-weight: 700;
    margin: 0 0 1.25rem;
  }
  .lede {
    font-size: 1.2rem;
    color: var(--fg-muted);
    margin: 0 0 2rem;
  }
  .ctas {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }
  /* ChatGPT-style intake box (home hero). */
  .intake {
    background: var(--gh-surface);
    border: 1px solid var(--gh-line);
    border-radius: var(--gh-radius-md);
    box-shadow: var(--gh-shadow-card);
    padding: 0.75rem 0.75rem 0.6rem;
    max-width: 34rem;
  }
  .intake-text {
    width: 100%;
    border: 0;
    resize: none;
    background: transparent;
    font-family: var(--gh-font-body);
    font-size: 1rem;
    color: var(--gh-ink-900);
    line-height: 1.5;
    padding: 0.25rem;
  }
  .intake-text:focus {
    outline: none;
  }
  /* Light, on-brand hint text so users know how to use the box. */
  .intake-text::placeholder {
    color: var(--gh-ink-500);
    opacity: 1;
  }
  .intake-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.4rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--gh-line);
  }
  .intake-hint {
    font-size: 0.8rem;
    color: var(--gh-ink-500);
  }
  .intake-go {
    border: 0;
    cursor: pointer;
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .primary {
    display: inline-block;
    padding: 0.8rem 1.6rem;
    background: var(--gh-maroon-600);
    color: #fff;
    border-radius: var(--gh-radius-pill);
    font-family: var(--gh-font-brand);
    font-weight: 600;
    transition: background var(--gh-dur-fast) var(--gh-ease), transform var(--gh-dur-fast) var(--gh-ease);
  }
  .primary:hover {
    background: var(--gh-maroon-700);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .secondary {
    display: inline-block;
    padding: 0.8rem 1.25rem;
    color: var(--gh-teal-700);
    font-family: var(--gh-font-brand);
    font-weight: 600;
  }
  .trust {
    font-size: 0.85rem;
    color: var(--fg-muted);
    margin: 1.5rem 0 0;
  }
  .media :global(img) {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  /* Scene art is flat brand illustration — no photo chrome. */
  .media.art :global(img) {
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }
  @media (max-width: 900px) {
    .hero.has-image {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    /* Guide: scene art stacks ABOVE the H1 on mobile (photos stay below). */
    .media.art {
      order: -1;
      max-width: 26rem;
      margin: 0 auto;
    }
    /* Center the hero on small screens to match the centered stacked art. */
    .copy {
      margin: 0 auto;
      text-align: center;
    }
    .ctas {
      justify-content: center;
    }
  }
</style>
