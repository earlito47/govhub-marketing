---
// Two on-brand, static SVG charts for the case-studies hub. Single-hue magnitude
// bars (brand blue), values direct-labeled in ink, recessive axes, bar heights
// strictly proportional to values. Each figure carries a title/desc for a11y and
// a visually-hidden data table for screen readers and SEO. No client JS.

// ---- Chart 1: proposal development time (hours), typical vs with GovHub ----
const c1 = {
  max: 250,
  ticks: [0, 50, 100, 150, 200, 250],
  bars: [
    { label: 'Typical', sub: 'no GovHub', hours: 250, emphasis: false },
    { label: 'With GovHub', sub: '', hours: 80, emphasis: true },
  ],
};

// ---- Chart 2: contract value by representative scenario (USD millions) ----
const c2 = {
  max: 50,
  ticks: [0, 10, 20, 30, 40, 50],
  bars: [
    { agency: 'USAF', sub: 'STTR II', value: 1.79, display: '$1.79M' },
    { agency: 'DHA', sub: 'Financial mgmt', value: 11.6, display: '$11.6M' },
    { agency: 'SBA', sub: 'IT service desk', value: 49, display: '~$49M' },
    { agency: 'DOC', sub: 'IT modernization', value: 6.5, display: '$6.5M' },
    { agency: 'VA', sub: 'Cybersecurity', value: 9.8, display: '$9.8M' },
  ],
};

// Chart 1 geometry
const W1 = 600, H1 = 340, top1 = 62, bottom1 = 62;
const plotH1 = H1 - top1 - bottom1;
const base1 = top1 + plotH1;
const bw1 = 130;
const cx1 = [175, 425]; // bar centers
const y1 = (v: number) => top1 + plotH1 * (1 - v / c1.max);

// Chart 2 geometry
const W2 = 600, H2 = 340, top2 = 52, bottom2 = 74, left2 = 40, right2 = 16;
const plotH2 = H2 - top2 - bottom2;
const base2 = top2 + plotH2;
const plotW2 = W2 - left2 - right2;
const band2 = plotW2 / c2.bars.length;
const bw2 = 62;
const y2 = (v: number) => top2 + plotH2 * (1 - v / c2.max);
---

<div class="charts">
  <figure class="chart">
    <figcaption>
      <strong>Proposal development time — typical vs. with GovHub</strong>
      <span>Representative average across the case studies below</span>
    </figcaption>
    <svg viewBox={`0 0 ${W1} ${H1}`} role="img" aria-label="Bar chart: typical proposal development takes about 250 hours (10-plus weeks); with GovHub it takes about 80 hours (3 to 4 weeks), a 55 to 65 percent reduction.">
      {c1.ticks.map((t) => (
        <g>
          <line class="grid" x1="40" x2={W1 - 20} y1={y1(t)} y2={y1(t)} />
          <text class="axis-label" x="34" y={y1(t) + 4} text-anchor="end">{t}</text>
        </g>
      ))}
      <line class="axis" x1="40" x2={W1 - 20} y1={base1} y2={base1} />
      {c1.bars.map((b, i) => (
        <g>
          <rect
            class:list={['bar', b.emphasis ? 'bar-main' : 'bar-muted']}
            x={cx1[i] - bw1 / 2}
            y={y1(b.hours)}
            width={bw1}
            height={base1 - y1(b.hours)}
            rx="5"
          />
          <text class="val" x={cx1[i]} y={y1(b.hours) - 26} text-anchor="middle">{b.hours} hrs</text>
          <text class="cat" x={cx1[i]} y={base1 + 24} text-anchor="middle">{b.label}</text>
          {b.sub && <text class="cat-sub" x={cx1[i]} y={base1 + 42} text-anchor="middle">({b.sub})</text>}
        </g>
      ))}
      <text class="callout" x={cx1[1]} y={y1(80) - 52} text-anchor="middle">~55–65% less time</text>
    </svg>
    <table class="sr-only">
      <caption>Proposal development time, typical vs. with GovHub</caption>
      <thead><tr><th>Scenario</th><th>Hours</th><th>Duration</th></tr></thead>
      <tbody>
        <tr><td>Typical (no GovHub)</td><td>~250</td><td>10+ weeks</td></tr>
        <tr><td>With GovHub</td><td>~80</td><td>3–4 weeks</td></tr>
      </tbody>
    </table>
  </figure>

  <figure class="chart">
    <figcaption>
      <strong>Contract value by representative scenario</strong>
      <span>~$78.7M total across five representative small-business wins (USD millions)</span>
    </figcaption>
    <svg viewBox={`0 0 ${W2} ${H2}`} role="img" aria-label="Bar chart of contract value in USD millions across five representative scenarios: Air Force STTR 1.79 million, DHA 11.6 million, SBA about 49 million, Commerce 6.5 million, VA 9.8 million.">
      {c2.ticks.map((t) => (
        <g>
          <line class="grid" x1={left2} x2={W2 - right2} y1={y2(t)} y2={y2(t)} />
          <text class="axis-label" x={left2 - 6} y={y2(t) + 4} text-anchor="end">{t}</text>
        </g>
      ))}
      <line class="axis" x1={left2} x2={W2 - right2} y1={base2} y2={base2} />
      {c2.bars.map((b, i) => {
        const cx = left2 + band2 * i + band2 / 2;
        return (
          <g>
            <rect class="bar bar-main" x={cx - bw2 / 2} y={y2(b.value)} width={bw2} height={base2 - y2(b.value)} rx="5" />
            <text class="val" x={cx} y={y2(b.value) - 10} text-anchor="middle">{b.display}</text>
            <text class="cat" x={cx} y={base2 + 22} text-anchor="middle">{b.agency}</text>
            <text class="cat-sub" x={cx} y={base2 + 40} text-anchor="middle">{b.sub}</text>
          </g>
        );
      })}
    </svg>
    <table class="sr-only">
      <caption>Contract value by representative scenario (USD millions)</caption>
      <thead><tr><th>Scenario</th><th>Agency</th><th>Contract value</th></tr></thead>
      <tbody>
        <tr><td>AI / STTR Phase II</td><td>U.S. Air Force</td><td>$1.79M</td></tr>
        <tr><td>Financial &amp; program management</td><td>Defense Health Agency</td><td>$11.6M</td></tr>
        <tr><td>IT service desk</td><td>Small Business Administration</td><td>~$49M</td></tr>
        <tr><td>IT modernization</td><td>Dept. of Commerce</td><td>$6.5M</td></tr>
        <tr><td>Cybersecurity</td><td>Dept. of Veterans Affairs</td><td>$9.8M</td></tr>
      </tbody>
    </table>
  </figure>
</div>

<style>
  .charts {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    margin: 2rem 0;
  }
  .chart {
    margin: 0;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 0.9rem;
    padding: 1.25rem 1.25rem 0.75rem;
    box-shadow: var(--shadow);
  }
  figcaption {
    margin-bottom: 0.5rem;
  }
  figcaption strong {
    display: block;
    color: var(--fg);
    font-size: 1rem;
  }
  figcaption span {
    color: var(--fg-muted);
    font-size: 0.85rem;
  }
  svg {
    width: 100%;
    height: auto;
    display: block;
    font-family: inherit;
  }
  .grid {
    stroke: var(--border);
    stroke-width: 1;
  }
  .axis {
    stroke: var(--fg-muted);
    stroke-width: 1.5;
    opacity: 0.5;
  }
  .bar-main {
    fill: var(--gh-navy-600);
  }
  .bar-muted {
    fill: var(--gh-tint-navy);
  }
  .val {
    fill: var(--fg);
    font-weight: 700;
    font-size: 15px;
  }
  .cat {
    fill: var(--fg);
    font-weight: 600;
    font-size: 13px;
  }
  .cat-sub {
    fill: var(--fg-muted);
    font-size: 11px;
  }
  .axis-label {
    fill: var(--fg-muted);
    font-size: 11px;
  }
  .callout {
    fill: var(--gh-navy-600);
    font-weight: 700;
    font-size: 15px;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
