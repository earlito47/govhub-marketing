---
// Tile-grid US choropleth (spec 7.1 map): every state is a square in an
// approximate US layout, shaded by value across five quantile bins. Compact
// inline SVG (no geographic paths, no client JS), so it's cheap to repeat and
// reads cleanly at any size. Sequential warm ramp: pale sand (low) → brick
// maroon (high). Carries hover titles + a visually-hidden data table.
import { formatUsdCompact } from '../../lib/insightsFormat';

interface Datum {
  code: string;
  name: string;
  value: number;
}
interface Props {
  data: Datum[];
  title: string;
  sourceLabel?: string;
  /** Link each state tile to its /insights/state/<slug>/ page (default on). */
  linkStates?: boolean;
}

const { data, title, sourceLabel = 'Source: USAspending.gov · GovHub Insights', linkStates = true } = Astro.props;

// USPS code -> state page slug, so every tile can deep-link to its dashboard.
const STATE_SLUG: Record<string, string> = {
  AK: "alaska", AL: "alabama", AR: "arkansas", AZ: "arizona", CA: "california", CO: "colorado",
  CT: "connecticut", DC: "district-of-columbia", DE: "delaware", FL: "florida", GA: "georgia", HI: "hawaii",
  IA: "iowa", ID: "idaho", IL: "illinois", IN: "indiana", KS: "kansas", KY: "kentucky",
  LA: "louisiana", MA: "massachusetts", MD: "maryland", ME: "maine", MI: "michigan", MN: "minnesota",
  MO: "missouri", MS: "mississippi", MT: "montana", NC: "north-carolina", ND: "north-dakota", NE: "nebraska",
  NH: "new-hampshire", NJ: "new-jersey", NM: "new-mexico", NV: "nevada", NY: "new-york", OH: "ohio",
  OK: "oklahoma", OR: "oregon", PA: "pennsylvania", RI: "rhode-island", SC: "south-carolina", SD: "south-dakota",
  TN: "tennessee", TX: "texas", UT: "utah", VA: "virginia", VT: "vermont", WA: "washington",
  WI: "wisconsin", WV: "west-virginia", WY: "wyoming",
};

// (row, col) tile positions — 8 rows × 11 cols, 50 states + DC.
const GRID: Record<string, [number, number]> = {
  AK: [0, 0], ME: [0, 10],
  VT: [1, 9], NH: [1, 10],
  WA: [2, 0], ID: [2, 1], MT: [2, 2], ND: [2, 3], MN: [2, 4], IL: [2, 5], WI: [2, 6], MI: [2, 7], NY: [2, 9], MA: [2, 10],
  OR: [3, 0], NV: [3, 1], WY: [3, 2], SD: [3, 3], IA: [3, 4], IN: [3, 5], OH: [3, 6], PA: [3, 7], NJ: [3, 8], CT: [3, 9], RI: [3, 10],
  CA: [4, 0], UT: [4, 1], CO: [4, 2], NE: [4, 3], MO: [4, 4], KY: [4, 5], WV: [4, 6], VA: [4, 7], MD: [4, 8], DE: [4, 9],
  AZ: [5, 1], NM: [5, 2], KS: [5, 3], AR: [5, 4], TN: [5, 5], NC: [5, 6], SC: [5, 7], DC: [5, 8],
  OK: [6, 3], LA: [6, 4], MS: [6, 5], AL: [6, 6], GA: [6, 7],
  HI: [7, 0], TX: [7, 3], FL: [7, 8],
};

const RAMP = ['#FBEFD9', '#F3C87E', '#E8A23D', '#C86B3C', '#A03A2C']; // sand → gold → brick
const byCode = new Map(data.map((d) => [d.code, d]));
const values = data.map((d) => d.value).sort((a, b) => a - b);
// Quantile thresholds (20/40/60/80th percentile) → balanced 5-bin shading.
const q = (p: number) => values[Math.min(values.length - 1, Math.floor(p * values.length))] ?? 0;
const thresholds = [q(0.2), q(0.4), q(0.6), q(0.8)];
const binOf = (v: number) => thresholds.reduce((b, t) => b + (v > t ? 1 : 0), 0);

const TILE = 46;
const STRIDE = 50;
const COLS = 11;
const ROWS = 8;
const W = COLS * STRIDE;
const gridH = ROWS * STRIDE;
const legendY = gridH + 18;
const H = legendY + 46;

const tiles = Object.entries(GRID).map(([code, [row, col]]) => {
  const d = byCode.get(code);
  const bin = d ? binOf(d.value) : 0;
  return {
    code,
    x: col * STRIDE,
    y: row * STRIDE,
    fill: d ? RAMP[bin] : '#EDE6D8',
    dark: bin >= 3,
    name: d?.name ?? code,
    value: d ? (formatUsdCompact(d.value) ?? '—') : 'n/a',
    href: linkStates && STATE_SLUG[code] ? `/insights/state/${STATE_SLUG[code]}/` : null,
  };
});

const legend = RAMP.map((color, i) => ({
  color,
  x: i * 92,
  label: i === 0 ? 'Lower' : i === RAMP.length - 1 ? 'Higher' : '',
  threshold: i > 0 ? formatUsdCompact(thresholds[i - 1]) : null,
}));
---

<figure class="us-map">
  <figcaption><strong>{title}</strong></figcaption>
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label={`${title}. Choropleth map of US states shaded by value.`}>
    <title>{title}</title>
    {tiles.map((t) => {
      const tile = (
        <g class="tile">
          <title>{t.name}: {t.value}</title>
          <rect x={t.x} y={t.y} width={TILE} height={TILE} rx="6" fill={t.fill} />
          <text
            x={t.x + TILE / 2}
            y={t.y + TILE / 2}
            text-anchor="middle"
            dominant-baseline="central"
            class:list={['abbr', { dark: t.dark }]}
          >{t.code}</text>
        </g>
      );
      return t.href ? <a href={t.href} class="tile-link" aria-label={`${t.name} federal contracts`}>{tile}</a> : tile;
    })}
    {/* Legend */}
    {legend.map((l) => (
      <g>
        <rect x={l.x} y={legendY} width="84" height="14" rx="3" fill={l.color} />
        {l.threshold && <text class="legend-tick" x={l.x} y={legendY + 30} text-anchor="middle">{l.threshold}</text>}
        {l.label && <text class="legend-end" x={l.label === 'Lower' ? l.x : l.x + 84} y={legendY - 6} text-anchor={l.label === 'Lower' ? 'start' : 'end'}>{l.label}</text>}
      </g>
    ))}
  </svg>
  <figcaption class="source-line">{sourceLabel}</figcaption>

  <table class="sr-only">
    <caption>{title}</caption>
    <thead><tr><th scope="col">State</th><th scope="col">Value</th></tr></thead>
    <tbody>{data.map((d) => (<tr><td>{d.name}</td><td>{formatUsdCompact(d.value)}</td></tr>))}</tbody>
  </table>
</figure>

<style>
  .us-map {
    margin: 1.25rem 0 0;
    background: var(--gh-surface);
    border: 1px solid var(--gh-line);
    border-radius: var(--gh-radius-md);
    padding: 1.25rem 1.25rem 1rem;
    box-shadow: var(--gh-shadow-card);
  }
  figcaption strong {
    display: block;
    color: var(--fg);
    font-size: 1.02rem;
    font-family: var(--gh-font-brand);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  svg { width: 100%; height: auto; display: block; font-family: var(--gh-font-body); max-width: 640px; margin: 0 auto; }
  .abbr { font-size: 15px; font-weight: 600; fill: var(--gh-ink-900); }
  .abbr.dark { fill: var(--gh-ink-inverse); }
  .tile rect { stroke: rgba(255,255,255,0.65); stroke-width: 1; transition: stroke 0.12s; }
  .tile-link { cursor: pointer; }
  .tile-link:hover rect,
  .tile-link:focus-visible rect { stroke: var(--gh-ink-900); stroke-width: 2; }
  .tile-link:focus-visible { outline: none; }
  .legend-tick { font-size: 12px; fill: var(--fg-muted); }
  .legend-end { font-size: 12px; fill: var(--fg-muted); font-weight: 600; }
  .source-line { color: var(--fg-muted); font-size: 0.8rem; margin-top: 0.5rem; }
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }
</style>
