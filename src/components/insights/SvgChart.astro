---
/**
 * Server-rendered inline SVG chart — no client JS, no charting library
 * (hard constraint #3). Supports `line` (trends) and `bar` (horizontal
 * rankings). Every chart carries a <title>/aria-label, a visually-hidden data
 * table (screen readers + SEO, since crawlers can't read SVG), and a visible
 * one-sentence takeaway. Brand: gold primary series, charcoal text/axes.
 */
import type { Chart } from '../../lib/insightsTypes';
import { formatUsdCompact, formatPercent } from '../../lib/insightsFormat';

interface Props {
  chart: Chart;
}

const { chart } = Astro.props;
const points = chart.series[0]?.points ?? [];
const isUsd = chart.unit === 'usd';
const isPct = chart.unit === 'pct';
const fmt = (v: number): string =>
  isUsd ? (formatUsdCompact(v) ?? String(v)) : isPct ? (formatPercent(v) ?? String(v)) : String(v);

const ariaLabel = chart.takeaway ?? `${chart.title}: ${points.length} data points.`;

// ---- Bar (horizontal ranking) geometry ----
const BW = 800;
const rowStride = 44;
const barH = 22;
const padTop = 10;
const padBottom = 10;
const labelW = 250;
const gutter = 14;
const valueColW = 90;
const plotX = labelW + gutter;
const barPlotW = BW - plotX - valueColW;
const barMax = Math.max(...points.map((p) => p[1]), 1);
const BH = padTop + points.length * rowStride + padBottom;

// Federal contractor/agency legal names routinely run 30–45 chars, which a
// single truncated line would clip ("TRIWEST HEALTHCARE ALLI…"). Instead wrap
// long labels onto up to two lines at word boundaries so the full name shows;
// only an extreme third-line overflow (very rare) falls back to an ellipsis.
const LABEL_MAX_LINE = 28;
const wrapLabel = (s: string): string[] => {
  if (s.length <= LABEL_MAX_LINE) return [s];
  const words = s.split(' ');
  const lines: string[] = [];
  let cur = '';
  for (const word of words) {
    const next = cur ? `${cur} ${word}` : word;
    if (cur && next.length > LABEL_MAX_LINE) {
      lines.push(cur);
      cur = word;
    } else {
      cur = next;
    }
  }
  if (cur) lines.push(cur);
  if (lines.length > 2) {
    // Collapse any overflow into the second line, then ellipsize if needed.
    let second = lines.slice(1).join(' ');
    if (second.length > LABEL_MAX_LINE) second = `${second.slice(0, LABEL_MAX_LINE - 1)}…`;
    return [lines[0], second];
  }
  return lines;
};

const bars = points.map((p, i) => {
  const rowY = padTop + i * rowStride;
  const cy = rowY + rowStride / 2;
  const w = barPlotW * (p[1] / barMax);
  const rawLabel = p[0];
  const lines = wrapLabel(rawLabel);
  return { i, cy, barY: cy - barH / 2, w, lines, rawLabel, value: fmt(p[1]) };
});

// ---- Line (trend) geometry ----
const LW = 800;
const LH = 430;
const padL = 66;
const padR = 28;
const padT = 26;
const padB = 54;
const plotW = LW - padL - padR;
const plotH = LH - padT - padB;
const n = points.length;
const lineMax = Math.max(...points.map((p) => p[1]), 1) * 1.12;
const xAt = (i: number): number => (n > 1 ? padL + (plotW * i) / (n - 1) : padL + plotW / 2);
const yAt = (v: number): number => padT + plotH * (1 - v / lineMax);
const linePts = points.map((p, i) => ({ x: xAt(i), y: yAt(p[1]), label: p[0], value: fmt(p[1]) }));
const polyline = linePts.map((p) => `${p.x},${p.y}`).join(' ');
const areaPath =
  linePts.length > 0
    ? `M ${linePts[0].x},${padT + plotH} ${linePts.map((p) => `L ${p.x},${p.y}`).join(' ')} L ${linePts[n - 1].x},${padT + plotH} Z`
    : '';
const gridFracs = [0, 0.25, 0.5, 0.75, 1];
const last = linePts[n - 1];
---

<figure class="ins-chart">
  <figcaption>
    <strong>{chart.title}</strong>
  </figcaption>

  {chart.type === 'bar' ? (
    <svg viewBox={`0 0 ${BW} ${BH}`} role="img" aria-label={ariaLabel} class="bar-svg">
      <title>{chart.title}</title>
      {bars.map((b) => (
        <g class="bar-row">
          {b.i < 3 ? (
            <g>
              <circle class="rank-badge" cx="18" cy={b.cy} r="11" />
              <text class="rank-badge-num" x="18" y={b.cy} text-anchor="middle" dominant-baseline="central">{b.i + 1}</text>
            </g>
          ) : (
            <text class="rank-plain" x="18" y={b.cy} text-anchor="middle" dominant-baseline="central">{b.i + 1}</text>
          )}
          {b.lines.length === 1 ? (
            <text class="bar-label" x="40" y={b.cy} dominant-baseline="central">{b.lines[0]}</text>
          ) : (
            <text class="bar-label" x="40" y={b.cy} dominant-baseline="central">
              <tspan x="40" dy="-0.55em">{b.lines[0]}</tspan>
              <tspan x="40" dy="1.1em">{b.lines[1]}</tspan>
            </text>
          )}
          <rect class="bar-track" x={plotX} y={b.barY} width={barPlotW} height={barH} rx="5" />
          <rect class="bar-fill" x={plotX} y={b.barY} width={Math.max(b.w, 2)} height={barH} rx="5" style={`animation-delay:${b.i * 40}ms`} />
          <text class="bar-value" x={plotX + Math.max(b.w, 2) + 8} y={b.cy} dominant-baseline="central">{b.value}</text>
        </g>
      ))}
    </svg>
  ) : (
    <svg viewBox={`0 0 ${LW} ${LH}`} role="img" aria-label={ariaLabel} class="line-svg">
      <title>{chart.title}</title>
      {gridFracs.map((f) => {
        const y = padT + plotH * (1 - f);
        return (
          <g>
            <line class="grid" x1={padL} x2={LW - padR} y1={y} y2={y} />
            <text class="axis-y" x={padL - 10} y={y} text-anchor="end" dominant-baseline="central">{fmt(lineMax * f)}</text>
          </g>
        );
      })}
      {areaPath && <path class="line-area" d={areaPath} />}
      <polyline class="line-stroke" points={polyline} />
      {linePts.map((p, i) => (
        <g>
          <circle class:list={['line-dot', { last: i === n - 1 }]} cx={p.x} cy={p.y} r={i === n - 1 ? 5.5 : 3.5} />
          <text class="axis-x" x={p.x} y={padT + plotH + 22} text-anchor="middle">{p.label}</text>
        </g>
      ))}
      {last && <text class="line-last-value" x={last.x} y={last.y - 14} text-anchor="middle">{last.value}</text>}
    </svg>
  )}

  <table class="sr-only">
    <caption>{chart.title}</caption>
    <thead><tr><th scope="col">Item</th><th scope="col">{chart.series[0]?.label ?? 'Value'}</th></tr></thead>
    <tbody>
      {points.map((p) => (<tr><td>{p[0]}</td><td>{fmt(p[1])}</td></tr>))}
    </tbody>
  </table>
</figure>

{chart.takeaway && <p class="chart-takeaway">{chart.takeaway}</p>}

<style>
  .ins-chart {
    margin: 1.25rem 0 0;
    background: var(--gh-surface);
    border: 1px solid var(--gh-line);
    border-radius: var(--gh-radius-md);
    padding: 1.25rem 1.25rem 1rem;
    box-shadow: var(--gh-shadow-card);
  }
  figcaption strong {
    display: block;
    color: var(--fg);
    font-size: 1.02rem;
    font-family: var(--gh-font-brand);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  svg {
    width: 100%;
    height: auto;
    display: block;
    font-family: var(--gh-font-body);
  }

  /* Bars */
  .bar-track { fill: var(--gh-ink-900); opacity: 0.06; }
  .bar-fill { fill: var(--gh-gold-400); }
  .bar-label { fill: var(--gh-ink-900); font-size: 12px; font-weight: 500; }
  .bar-value { fill: var(--gh-ink-900); font-size: 14px; font-weight: 700; }
  .rank-badge { fill: var(--gh-gold-400); }
  .rank-badge-num { fill: var(--gh-ink-900); font-size: 12px; font-weight: 700; }
  .rank-plain { fill: var(--gh-ink-500); font-size: 12px; font-weight: 600; }

  /* Line */
  .grid { stroke: var(--gh-tint-sand); stroke-width: 1; opacity: 0.5; }
  .axis-y, .axis-x { fill: var(--gh-ink-500); font-size: 13px; }
  .line-area { fill: var(--gh-gold-400); opacity: 0.1; }
  .line-stroke { fill: none; stroke: var(--gh-gold-400); stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }
  .line-dot { fill: var(--gh-gold-400); }
  .line-dot.last { fill: var(--gh-maroon-600); }
  .line-last-value { fill: var(--gh-ink-900); font-size: 14px; font-weight: 700; }

  /* One tasteful motion touch: bars grow from the left, staggered. */
  @media (prefers-reduced-motion: no-preference) {
    .bar-fill {
      transform-box: fill-box;
      transform-origin: left center;
      animation: bar-grow 320ms cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    @keyframes bar-grow {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
