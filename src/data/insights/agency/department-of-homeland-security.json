  "narrative": {
    "intro": "Department of Homeland Security contract obligations for FY2026 to date total $52B across 19,582 awards with an average award size of $2.7M. Obligations are up 83.8% year over year. Annual obligations listed by fiscal year show a rising profile from $19.7B in FY21 to $28.3B in FY25, with FY26 to date at $52B. The FY2026 to date portfolio is concentrated in a few large NAICS categories and vendors, with Commercial and Institutional Building Construction accounting for $28.4B and the top vendor, FISHER SAND & GRAVEL CO, receiving $13.3B. The dataset is partial for the current fiscal year, but the year-over-year increase and the concentration by category and vendor indicate where most obligations are recorded so far in FY2026 to date.",
    "sections": [
      {
        "heading": "How has DHS contract spending changed year over year?",
        "body": "Obligations are up 83.8% year over year. Total obligations for FY2026 to date are $52B compared with $28.3B in FY25 and $23.6B in FY24. The number of awards for FY2026 to date is 19,582 with an average award size of $2.7M."
      },
      {
        "heading": "Where is DHS spending concentrated?",
        "body": "Commercial and Institutional Building Construction accounts for $28.4B of FY2026 to date obligations. Ship Building and Repairing and Security Guards and Patrol Services account for $4.2B and $3.1B respectively, and the top vendor FISHER SAND & GRAVEL CO has received $13.3B."
      }
    ]
  },
  "faq": [
    {
      "q": "How much does Department of Homeland Security spend on contracts?",
      "a": "DHS has $52B in contract obligations for FY2026 to date. Those obligations are distributed across 19,582 awards with an average award size of $2.7M and are up 83.8% year over year."
    },
    {
      "q": "What does Homeland Security buy?",
      "a": "DHS buys primarily construction, shipbuilding, security, logistics, and IT services. The top NAICS categories for FY2026 to date are Commercial and Institutional Building Construction at $28.4B; Ship Building and Repairing at $4.2B; Security Guards and Patrol Services at $3.1B; Process, Physical Distribution, and Logistics Consulting Services at $2.6B; and Computer Systems Design Services at $1.5B."
    },
    {
      "q": "Who are Homeland Security's largest contractors?",
      "a": "DHS's largest contractors for FY2026 to date are led by FISHER SAND & GRAVEL CO at $13.3B. Other top vendors include BARNARD CONSTRUCTION COMPANY, INCORPORATED at $4.5B; SLS FEDERAL SERVICES LLC at $2.4B; SPENCER CONSTRUCTION LLC at $2.4B; and SOUTHWEST VALLEY CONSTRUCTORS CO at $2.2B."
    }
  ],
