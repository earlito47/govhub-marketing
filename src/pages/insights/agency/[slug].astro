---
// Agency entity dashboard — one page per file in src/data/insights/agency/.
import type { GetStaticPaths } from 'astro';
import type { InsightsPage } from '../../../lib/insightsTypes';
import InsightsLayout from '../../../components/insights/InsightsLayout.astro';
import EntityDashboard from '../../../components/insights/EntityDashboard.astro';

export const getStaticPaths = (() => {
  const files = import.meta.glob<{ default: InsightsPage }>('../../../data/insights/agency/*.json', { eager: true });
  return Object.entries(files).map(([path, mod]) => {
    const slug = path.split('/').pop()!.replace('.json', '');
    return { params: { slug }, props: { page: mod.default } };
  });
}) satisfies GetStaticPaths;

interface Props {
  page: InsightsPage;
}

const { page } = Astro.props;
const canonical = new URL(`/insights/agency/${page.slug}/`, Astro.site).toString();
---

<InsightsLayout
  title={page.title}
  noindex={page.noindex}
  description={page.metaDescription}
  dataset={{
    name: `Federal contract obligations: ${page.h1.split(':')[0]}`,
    description: page.metaDescription,
    dateModified: page.updated,
    temporalCoverage: `${page.fyWindow.start}/${page.fyWindow.end}`,
    url: canonical,
  }}
>
  <EntityDashboard
    page={page}
    breadcrumbs={[
      { name: 'Home', url: '/' },
      { name: 'Insights', url: '/insights/' },
      { name: 'Agencies', url: '/insights/#agencies' },
      { name: page.h1.split(':')[0], url: `/insights/agency/${page.slug}/` },
    ]}
    eyebrow="Federal agency contract profile"
    campaign="agency"
    dodLag={true}
    relatedHeading="Other federal agencies"
  />
</InsightsLayout>
