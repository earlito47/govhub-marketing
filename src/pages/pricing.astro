---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import PricingTable from '../components/PricingTable.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';
import CTABand from '../components/CTABand.astro';
import { PLANS, PRICE_RANGE, TRIAL_DAYS, formatUsd } from '../data/pricing';
import { faqsForPage } from '../data/faqs';
import PageHero from '../components/PageHero.astro';

// Cost FAQ comes from the shared data (single source of truth); the rest are
// pricing-page specific.
const pricingFaqs = [
  ...faqsForPage('/pricing/'),
  {
    question: `Is there a free trial?`,
    answer: `Yes — every paid plan includes a ${TRIAL_DAYS}-day free trial with no credit card required. You can generate real proposals during the trial and keep your work if you subscribe.`,
  },
  {
    question: 'Can I cancel or change plans anytime?',
    answer:
      'Yes. Plans are month-to-month (or annual for the discount) and you can upgrade, downgrade, or cancel at any time. Annual billing saves roughly two months versus paying monthly.',
  },
  {
    question: 'What counts as a proposal?',
    answer:
      'Each plan includes a set number of AI-drafted proposals per month — 3 on Solo, 15 on Pro, and 50 on Team. Reviewing, editing, and exporting a proposal does not consume additional allowance.',
  },
];
---

<BaseLayout
  title="Pricing Plans for AI Proposal Software | GovHub"
  description="Compare GovHub pricing for AI government proposal writing, form autofill, and compliance automation. Plans from $129/month with a 14-day free trial — no credit card required."
>
  <SchemaOrg
    type="SoftwareApplication"
    data={{
      name: 'GovHub',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: PRICE_RANGE.currency,
        lowPrice: PRICE_RANGE.low,
        highPrice: PRICE_RANGE.high,
        offerCount: PRICE_RANGE.offerCount,
      },
    }}
  />

  <main class="container">
    <PageHero art="/brand/page-graphics/pricing-three-peaks.svg">
    <header class="prose">
      <h1>Simple pricing for government proposal software</h1>
      <p class="lede">
        Plans scale with your proposal volume — from a solo consultant's first
        federal RFP to an agency's full pipeline. Every plan includes AI drafting,
        form autofill, and compliance-aware review, with a {TRIAL_DAYS}-day free
        trial and no credit card required.
      </p>
    </header>
    </PageHero>

    <PricingTable />

    <p class="range-note">
      GovHub runs from {formatUsd(PRICE_RANGE.low)}/month (Solo) to
      {formatUsd(PRICE_RANGE.high)}/month (Team), with a {formatUsd(PLANS[1].monthlyUsd)}/month
      Pro plan for teams responding regularly.
    </p>

    <FAQSchema faqs={pricingFaqs} heading="Pricing FAQ" />

    <CTABand
      heading="Start winning more government work"
      sub={`Try GovHub free for ${TRIAL_DAYS} days. No credit card required.`}
      secondaryHref="/solutions/"
      secondaryLabel="Explore the platform"
    />
  </main>
</BaseLayout>

<style>
  main {
    padding: 2rem 1.5rem 4rem;
  }
  header.prose {
    max-width: 44rem;
    margin: 1rem 0 2rem;
  }
  .lede {
    font-size: 1.15rem;
    color: var(--fg-muted);
    margin-top: 1rem;
  }
  .range-note {
    color: var(--fg-muted);
    font-size: 0.95rem;
    text-align: center;
    margin: 1.5rem auto 0;
    max-width: 42rem;
  }
</style>
