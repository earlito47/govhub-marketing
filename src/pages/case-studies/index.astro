---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import CTABand from '../../components/CTABand.astro';
import CaseStudyCharts from '../../components/CaseStudyCharts.astro';
import { caseStudies } from '../../data/case-studies';
import PageHero from '../../components/PageHero.astro';
---

<BaseLayout
  title="Case Studies: Small Business Federal Contract Wins | GovHub"
  description="How small businesses use GovHub to win federal contracts — from a $1.79M Air Force STTR to a ~$49M SBA IT vehicle. Scenarios grounded in public award data."
 ogImage="/brand/page-graphics/case-studies-carts-of-proof@2x.png">
  <main class="container">
    <Breadcrumbs
      items={[
        { name: 'Home', url: '/' },
        { name: 'Case studies', url: '/case-studies/' },
      ]}
    />

    <PageHero art="/brand/page-graphics/case-studies-carts-of-proof.svg">
    <header class="prose">
      <h1>Small businesses winning federal contracts with GovHub</h1>
      <p class="lede">
        Five representative scenarios — spanning the Air Force, DHA, SBA, Commerce,
        and the VA — showing how lean teams use GovHub to compete on quality
        against much larger firms. Together they reflect roughly
        <strong>$78.7M</strong> in small-business contract value.
      </p>
      <p class="disclaimer" role="note">
        <strong>Illustrative scenarios.</strong> These are representative examples
        grounded in real, public federal award data (SAM.gov, FPDS, USAspending) and
        anonymized — they show the kind of outcome GovHub is built to enable, not
        claims that specific named companies are customers.
      </p>
    </header>
    </PageHero>

    <CaseStudyCharts />

    {caseStudies.length > 0 ? (
      <ul class="cards">
        {caseStudies.map((c) => (
          <li>
            <a href={`/case-studies/${c.slug}/`}>
              <span class="tag">{c.industry}</span>
              <h2>{c.title}</h2>
              {c.contractValue && <p class="value">{c.contractValue}</p>}
              <p>{c.outcome}</p>
              <span class="more">Read the case study →</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">
        We're publishing case studies now. In the meantime, see
        <a href="/solutions/">what GovHub does</a> or start a free trial.
      </p>
    )}

    <CTABand heading="Write your own success story" sub="Start a free trial and put GovHub on your next solicitation." />
  </main>
</BaseLayout>

<style>
  main {
    padding: 1rem 1.5rem 4rem;
  }
  .prose {
    max-width: 46rem;
    margin: 1rem 0 1rem;
  }
  .lede {
    font-size: 1.15rem;
    color: var(--fg-muted);
    margin-top: 1rem;
  }
  .lede strong {
    color: var(--fg);
  }
  .disclaimer {
    font-size: 0.9rem;
    color: var(--fg-muted);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0.5rem;
    padding: 0.85rem 1.1rem;
    margin-top: 1.25rem;
  }
  .disclaimer strong {
    color: var(--fg);
  }
  .empty {
    color: var(--fg-muted);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }
  .cards {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .cards a {
    display: flex;
    flex-direction: column;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    color: inherit;
    box-shadow: var(--shadow);
  }
  .cards a:hover {
    border-color: var(--accent);
    text-decoration: none;
  }
  .tag {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
  }
  .cards h2 {
    margin: 0.4rem 0 0.25rem;
    font-size: 1.05rem;
  }
  .value {
    margin: 0 0 0.5rem;
    font-weight: 700;
    color: var(--fg);
  }
  .cards p {
    margin: 0 0 1rem;
    color: var(--fg-muted);
    font-size: 0.95rem;
    flex-grow: 1;
  }
  .more {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
