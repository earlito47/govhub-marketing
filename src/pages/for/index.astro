---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { audiences } from '../../data/audiences';
---

<BaseLayout
  title="GovHub for your team: solo to system integrator"
  description="GovHub adapts to who you are: solo consultants and small-business contractors winning federal work, or system integrators running large multi-team pursuits."
>
  <main class="container">
    <Breadcrumbs
      items={[
        { name: 'Home', url: '/' },
        { name: 'For', url: '/for/' },
      ]}
    />

    <header class="prose">
      <h1>Built for your side of the table</h1>
      <p class="lede">
        The same solicitation lands very differently on a two-person shop and a
        prime running a 30-contributor pursuit. GovHub scales to both.
      </p>
      <div class="gh-divider-ridge" aria-hidden="true"></div>
    </header>

    <ul class="cards">
      {audiences.map((a) => (
        <li>
          <a href={`/for/${a.slug}/`}>
            <h2>{a.name}</h2>
            <p>{a.headline}</p>
            <span class="more">See how →</span>
          </a>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>

<style>
  main {
    padding: 1rem 1.5rem 4rem;
  }
  .prose {
    max-width: 44rem;
    margin: 1rem 0 2rem;
  }
  .lede {
    font-size: 1.15rem;
    color: var(--fg-muted);
    margin-top: 1rem;
  }
  .cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .cards a {
    display: flex;
    flex-direction: column;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    color: inherit;
    box-shadow: var(--shadow);
  }
  .cards a:hover {
    border-color: var(--accent);
    text-decoration: none;
  }
  .cards h2 {
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
  }
  .cards p {
    margin: 0 0 1rem;
    color: var(--fg-muted);
    font-size: 0.95rem;
    flex-grow: 1;
  }
  .more {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
