---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSchema from '../../components/seo/FAQSchema.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import SchemaOrg from '../../components/seo/SchemaOrg.astro';
import { competitors, type Competitor } from '../../data/competitors';
import PageHero from '../../components/PageHero.astro';
import CTABand from '../../components/CTABand.astro';
import { SIGNUP_URL } from '../../config';

export function getStaticPaths() {
  return competitors.map((c) => ({
    params: { competitor: c.slug },
    props: { competitor: c },
  }));
}

interface Props {
  competitor: Competitor;
}

const { competitor } = Astro.props;
const isOpportunityIntel = competitor.category === 'opportunity-intelligence';

const title = isOpportunityIntel
  ? `GovHub and ${competitor.name}: how they compare`
  : `GovHub vs ${competitor.name}`;

// <title> uses the compact competitor name and a short qualifier to stay
// within the ~60-char SERP budget; the H1 keeps the full name.
const shortName = competitor.shortName ?? competitor.name;
const metaTitle = isOpportunityIntel
  ? `GovHub and ${shortName}: how they compare`
  : `GovHub vs ${shortName}: government proposal software`;

const description = isOpportunityIntel
  ? `${shortName} and GovHub solve different parts of the government contracting workflow. See how they compare, and why many teams use both.`
  : `Direct comparison of GovHub and ${shortName} for government contractors, where each fits, compliance and AI drafting differences, and which is right for you.`;
---

<BaseLayout title={metaTitle} description={description} ogImage="/brand/page-graphics/compare-weigh-options@2x.png">
  <SchemaOrg
    type="SoftwareApplication"
    data={{
      name: 'GovHub',
      description: 'AI proposal writing platform for government contractors.',
    }}
  />

  <main class="container">
    <Breadcrumbs
      items={[
        { name: 'Home', url: '/' },
        { name: 'Compare', url: '/vs/' },
        { name: competitor.name, url: `/vs/${competitor.slug}/` },
      ]}
    />

    <PageHero art="/brand/page-graphics/compare-weigh-options.svg">
      <header class="prose">
        <h1>{title}</h1>
      </header>
    </PageHero>

    <article class="prose">

      {isOpportunityIntel ? (
        <p class="lede">
          {competitor.name} is {competitor.tagline.toLowerCase().replace(/\.$/, '')}.
          GovHub is a proposal writing and compliance platform. These are
          <strong> different tools that solve different problems</strong>, many
          govcon teams use a discovery tool like {competitor.name} to find
          opportunities and a response tool like GovHub to write the proposals
          themselves.
        </p>
      ) : (
        <p class="lede">
          {competitor.name} is {competitor.tagline.toLowerCase().replace(/\.$/, '')}.
          It's best suited for {competitor.bestFor.toLowerCase().replace(/\.$/, '')}.
          GovHub is a government-specific alternative built around the structural
          conventions of federal, state, and local proposals. This page walks
          through how the two compare on the dimensions that matter for
          government contractors.
        </p>
      )}

      <div class="pricing-note" role="note">
        <strong>Estimated pricing for {competitor.name}:</strong> {competitor.pricingEstimate}
      </div>

      {isOpportunityIntel ? (
        <>
          <h2>Do you need both, or one or the other?</h2>
          <p>
            If your problem is <strong>finding opportunities</strong>, knowing
            which federal contracts are coming 12–36 months ahead of the RFP,
            {' '}{competitor.name} is designed for that. GovHub does not do
            opportunity discovery.
          </p>
          <p>
            If your problem is <strong>writing the proposal</strong> once you
            have a solicitation to respond to, drafting compliant Section
            L/M-structured content, running compliance matrices, managing FAR
            clause references, that's what GovHub is designed for.
            {' '}{competitor.name} does not do proposal writing or content
            generation.
          </p>
          <p>
            Many teams use both. A capture manager works in {competitor.name}
            to identify and pursue opportunities; the proposal team uses GovHub
            to respond to the ones that get pursued.
          </p>
        </>
      ) : (
        <h2>Quick answer: which one should you use?</h2>
      )}

      {!isOpportunityIntel && (
        <p>
          If your team primarily responds to <strong>government solicitations</strong>,
          federal RFPs, state and local RFQs, sources sought, or task orders on IDIQ
          vehicles, GovHub is designed for that workflow end to end. {competitor.name} is
          a strong choice for {competitor.bestFor.toLowerCase().replace(/\.$/, '')},
          but government-specific requirements (Section L/M structure, FAR/DFARS
          compliance, Section 508 conformance, set-aside representations) are not
          its primary design center.
        </p>
      )}

      <h2>Comparison at a glance</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Dimension</th>
              <th>GovHub</th>
              <th>{competitor.name}</th>
            </tr>
          </thead>
          <tbody>
            {competitor.comparisonPoints.map((p) => (
              <tr>
                <th scope="row">{p.label}</th>
                <td>{p.govhub}</td>
                <td>{p.competitor}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Where {competitor.name} is strong</h2>
      <ul>
        {competitor.strengths.map((s) => <li>{s}</li>)}
      </ul>

      <h2>{isOpportunityIntel ? `Where teams look elsewhere` : `Where GovHub wins for government work`}</h2>
      <ul>
        {competitor.weaknesses.map((w) => <li>{w}</li>)}
      </ul>

      {isOpportunityIntel ? (
        <>
          <h2>Can GovHub and {competitor.name} work together?</h2>
          <p>
            Yes, and for many teams, that's the natural setup.
            {' '}{competitor.name} handles the pre-solicitation intelligence
            work; GovHub handles the post-solicitation response work. The
            handoff point is the moment you decide to bid.
          </p>
        </>
      ) : (
        <>
          <h2>Should you switch from {competitor.name} to GovHub?</h2>
          <p>
            Switching makes sense if the majority of your responses are government
            solicitations and you are spending significant time working around
            {competitor.name}'s general-purpose design to fit government-specific
            requirements. If your response mix is mostly commercial B2B RFPs with
            occasional government work, staying on {competitor.name} may be the
            right call.
          </p>
        </>
      )}

      <p class="cta-pair">
        <a class="primary" href={SIGNUP_URL}>Start free trial</a>
        <a class="secondary" href="/pricing/">See pricing</a>
      </p>
    </article>

    <FAQSchema faqs={competitor.faqs} heading={`${title}: FAQ`} />

    <CTABand
      heading="Try the government-specific option"
      sub="Bring your next solicitation, the first draft is ready before the trial ends."
      secondaryHref="/pricing/"
      secondaryLabel="See pricing"
    />
  </main>
</BaseLayout>

<style>
  main {
    padding-bottom: 3rem;
  }
  .prose {
    max-width: 48rem;
    margin: 2rem 0 3rem;
  }
  .lede {
    font-size: 1.15rem;
    color: var(--fg-muted);
    margin-bottom: 2rem;
  }
  .pricing-note {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin: 2rem 0;
    font-size: 0.95rem;
    color: var(--fg-muted);
  }
  .pricing-note strong {
    color: var(--fg);
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.9rem;
  }
  h2 {
    margin-top: 2.5rem;
  }
  .table-wrap {
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  th,
  td {
    border: 1px solid var(--border);
    padding: 0.75rem 1rem;
    text-align: left;
    vertical-align: top;
  }
  thead th {
    background: var(--bg-elevated);
    color: var(--fg);
  }
  tbody th {
    background: var(--bg-elevated);
    color: var(--fg-muted);
    font-weight: 600;
    width: 22%;
  }
  td {
    color: var(--fg-muted);
  }
  ul {
    padding-left: 1.25rem;
    color: var(--fg-muted);
  }
  ul li {
    margin: 0.5rem 0;
  }
  .cta {
    margin-top: 2.5rem;
  }
  .cta a {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--accent);
    border-radius: 0.5rem;
  }
  .cta a:hover {
    background: var(--accent-soft);
    text-decoration: none;
  }
  .cta-pair {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }
  .cta-pair .primary {
    display: inline-block;
    padding: 0.75rem 1.6rem;
    background: var(--gh-maroon-600);
    color: #fff;
    border-radius: var(--gh-radius-pill);
    font-family: var(--gh-font-brand);
    font-weight: 600;
  }
  .cta-pair .primary:hover {
    background: var(--gh-maroon-700);
    text-decoration: none;
  }
  .cta-pair .secondary {
    display: inline-block;
    padding: 0.75rem 1.6rem;
    border: 2px solid var(--gh-navy-600);
    color: var(--gh-navy-600);
    border-radius: var(--gh-radius-pill);
    font-family: var(--gh-font-brand);
    font-weight: 600;
  }
  .cta-pair .secondary:hover {
    background: rgba(33, 75, 137, 0.07);
    text-decoration: none;
  }
</style>
