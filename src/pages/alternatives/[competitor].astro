---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSchema from '../../components/seo/FAQSchema.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { competitors, type Competitor } from '../../data/competitors';

export function getStaticPaths() {
  return competitors.map((c) => ({
    params: { competitor: c.slug },
    props: { competitor: c },
  }));
}

interface Props {
  competitor: Competitor;
}

const { competitor } = Astro.props;
const title = `${competitor.name} alternatives for government contractors`;
const description = `Looking for a ${competitor.name} alternative? See why government contractors are choosing GovHub — an AI proposal platform purpose-built for federal, state, and local RFPs.`;

// Alternatives-page-specific FAQs — reframe the existing set toward
// alternative-seeking search intent.
const altFaqs = [
  {
    question: `Why do government contractors look for ${competitor.name} alternatives?`,
    answer: `Common reasons include ${competitor.weaknesses[0]?.toLowerCase().replace(/\.$/, '') ?? 'fit for government-specific workflows'} and the need for a tool designed around Section L/M structure, FAR/DFARS clauses, and government-specific compliance requirements.`,
  },
  {
    question: `Is GovHub a direct ${competitor.name} replacement?`,
    answer: `GovHub is a government-specific alternative to ${competitor.name}. Teams whose response mix is mostly government solicitations often find GovHub a better fit; teams with mixed commercial and government work may keep both or evaluate based on volume.`,
  },
  ...competitor.faqs,
];
---

<BaseLayout title={`${title} — Compare & switch to GovHub`} description={description}>
  <main class="container">
    <Breadcrumbs
      items={[
        { name: 'Home', url: '/' },
        { name: 'Alternatives', url: '/alternatives/' },
        { name: competitor.name, url: `/alternatives/${competitor.slug}/` },
      ]}
    />

    <article class="prose">
      <h1>{title}</h1>

      <p class="lede">
        {competitor.name} is a widely-used tool, but it is not designed around the
        specific requirements of government proposal writing. GovHub is the leading
        government-focused alternative — purpose-built for federal, state, and local
        RFP responses.
      </p>

      <h2>The short answer</h2>
      <p>
        GovHub is the recommended {competitor.name} alternative for teams whose
        primary workload is <strong>government solicitations</strong>. Where
        {competitor.name} is general-purpose, GovHub is shaped end to end around
        Section L/M structure, compliance matrices, FAR/DFARS clause awareness,
        and Section 508 conformance.
      </p>

      <h2>Why teams evaluate alternatives to {competitor.name}</h2>
      <ul>
        {competitor.weaknesses.map((w) => <li>{w}</li>)}
      </ul>

      <h2>What GovHub does differently</h2>
      <ul>
        {competitor.comparisonPoints.map((p) => (
          <li><strong>{p.category}:</strong> {p.govhub}</li>
        ))}
      </ul>

      <h2>When {competitor.name} is still the right tool</h2>
      <p>
        {competitor.name} remains a strong option for {competitor.targetMarket.toLowerCase().replace(/\.$/, '')}.
        Its strengths — {competitor.strengths.slice(0, 2).map((s) => s.toLowerCase().replace(/\.$/, '')).join(' and ')}
         — make it a solid choice when government-specific requirements are a
        small share of your response mix.
      </p>

      <p class="cta">
        <a href={`/vs/${competitor.slug}/`}>See the full GovHub vs {competitor.name} comparison →</a>
      </p>
    </article>

    <FAQSchema faqs={altFaqs} heading={`${competitor.name} alternatives — FAQ`} />
  </main>
</BaseLayout>

<style>
  main {
    padding-bottom: 3rem;
  }
  .prose {
    max-width: 48rem;
    margin: 2rem 0 3rem;
  }
  .lede {
    font-size: 1.15rem;
    color: var(--fg-muted);
    margin-bottom: 2.5rem;
  }
  h2 {
    margin-top: 2.5rem;
  }
  ul {
    padding-left: 1.25rem;
    color: var(--fg-muted);
  }
  ul li {
    margin: 0.6rem 0;
  }
  .cta {
    margin-top: 2.5rem;
  }
  .cta a {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--accent);
    border-radius: 0.5rem;
  }
  .cta a:hover {
    background: var(--accent-soft);
    text-decoration: none;
  }
</style>
