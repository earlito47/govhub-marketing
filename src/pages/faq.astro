---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';
import { faqs } from '../data/faqs';
import { faqPages } from '../data/faqPages';
import PageHero from '../components/PageHero.astro';
import CTABand from '../components/CTABand.astro';
---

<BaseLayout
  title="AI Proposal Software FAQ for Government Contractors"
  description="Answers to common questions about GovHub, the AI proposal writing platform for government contractors."
 ogImage="/brand/page-graphics/faq-signpost@2x.png">
  <main class="container">
    <PageHero art="/brand/page-graphics/faq-signpost.svg">
    <header class="prose">
      <h1>Frequently asked questions</h1>
      <p class="lede">
        Common questions about GovHub, government proposal workflows, compliance,
        and pricing.
      </p>
    </header>
    </PageHero>

    <FAQSchema faqs={faqs} heading="All FAQs" />

    <section class="in-depth">
      <h2>Federal contracting questions, answered in full</h2>
      <p>Each of these has its own page, so you can link to it or find it the moment it comes up.</p>
      <ul>
        {faqPages.map((f) => (
          <li><a href={`/faq/${f.slug}/`}>{f.question}</a></li>
        ))}
      </ul>
      <p class="glossary-link">Prefer definitions? See the <a href="/glossary/">federal contracting glossary</a>.</p>
    </section>

    <CTABand
      heading="Answered everything? Try it on a real RFP."
      sub="Start a free 14-day trial and see the first draft on your own solicitation."
      secondaryHref="/pricing/"
      secondaryLabel="See pricing"
    />
  </main>
</BaseLayout>

<style>
  main {
    padding: 2rem 1.5rem 5rem;
  }
  header.prose {
    max-width: 42rem;
    margin: 2rem 0 1rem;
  }
  .lede {
    font-size: 1.1rem;
    color: var(--fg-muted);
    margin-top: 1rem;
  }
  .in-depth {
    max-width: 42rem;
    margin: 3rem 0 0;
  }
  .in-depth h2 {
    font-size: 1.4rem;
  }
  .in-depth > p {
    color: var(--fg-muted);
  }
  .in-depth ul {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .in-depth li a {
    display: block;
    padding: 0.85rem 1rem;
    background: var(--gh-surface);
    border: 1px solid var(--gh-line);
    border-radius: var(--gh-radius-sm);
    color: var(--gh-teal-700);
    font-weight: 600;
  }
  .in-depth li a:hover {
    border-color: var(--gh-teal-600);
    text-decoration: none;
  }
  .glossary-link {
    margin-top: 1.25rem;
    color: var(--fg-muted);
  }
</style>
