---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';
import { faqs } from '../data/faqs';
import PageHero from '../components/PageHero.astro';
import CTABand from '../components/CTABand.astro';
---

<BaseLayout
  title="AI Proposal Software FAQ for Government Contractors"
  description="Answers to common questions about GovHub, the AI proposal writing platform for government contractors."
 ogImage="/brand/page-graphics/faq-signpost@2x.png">
  <main class="container">
    <PageHero art="/brand/page-graphics/faq-signpost.svg">
    <header class="prose">
      <h1>Frequently asked questions</h1>
      <p class="lede">
        Common questions about GovHub, government proposal workflows, compliance,
        and pricing.
      </p>
    </header>
    </PageHero>

    <FAQSchema faqs={faqs} heading="All FAQs" />

    <CTABand
      heading="Answered everything? Try it on a real RFP."
      sub="Start a free 14-day trial and see the first draft on your own solicitation."
      secondaryHref="/pricing/"
      secondaryLabel="See pricing"
    />
  </main>
</BaseLayout>

<style>
  main {
    padding: 2rem 1.5rem 5rem;
  }
  header.prose {
    max-width: 42rem;
    margin: 2rem 0 1rem;
  }
  .lede {
    font-size: 1.1rem;
    color: var(--fg-muted);
    margin-top: 1rem;
  }
</style>
