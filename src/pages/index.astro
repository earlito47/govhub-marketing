---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import Hero from '../components/Hero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import SolutionsGrid from '../components/SolutionsGrid.astro';
import SocialProofMarquee from '../components/SocialProofMarquee.astro';
import StatRow from '../components/StatRow.astro';
import TrustSection from '../components/TrustSection.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';
import CTABand from '../components/CTABand.astro';
import Icon from '../components/Icon.astro';
import { PRIMARY_KEYWORD, SIGNUP_URL, TRIAL_DAYS } from '../config';
import { PRICE_RANGE, formatUsd } from '../data/pricing';
import { faqsForPage } from '../data/faqs';

// Primary term is single-sourced — see src/config.ts PRIMARY_KEYWORD.
// <title> keeps the exact-match phrase; the H1 carries it inside a real pitch.
const title = PRIMARY_KEYWORD.title;
const description = `GovHub is ${PRIMARY_KEYWORD.primary} built for federal, state, and local contractors — draft compliant RFP responses, autofill contract forms, and check Section L/M and FAR/DFARS compliance.`;

const features = [
  {
    title: 'Built for government work — not adapted to it',
    description:
      'Section L/M structure, evaluation-criteria alignment, and compliance matrices are the default, not a plugin bolted onto a commercial sales tool.',
    icon: 'capitol',
  },
  {
    title: 'Drafts that sound like your firm',
    description:
      'GovHub learns from your past-performance library and technical narrative, so the first draft reads like your best writer — not a generic template.',
    icon: 'pen',
  },
  {
    title: 'Compliance gaps caught before you submit',
    description:
      'Automated checks against FAR/DFARS clauses, Section 508, and set-aside requirements flag problems while there is still time to fix them.',
    icon: 'shield-check',
  },
  {
    title: 'Grows from your first bid to a full pipeline',
    description:
      'Works for a one-person shop answering its first federal RFP, and for multi-team pursuits with dozens of contributors.',
    icon: 'team',
  },
];

const steps = [
  {
    n: '1',
    icon: 'map',
    title: 'Upload the RFP',
    body: 'Import the solicitation (PDF, SAM.gov URL, or agency export). GovHub “shreds” it to surface every requirement, instruction, and evaluation factor — including easy-to-miss compliance criteria.',
  },
  {
    n: '2',
    icon: 'shovel',
    title: 'Add your company info',
    body: 'Look your company up — GovHub pulls your UEI, CAGE, NAICS, and certifications straight from SAM.gov and your website, or extracts them from your capability statements. It maps your strengths to the RFP’s requirements automatically.',
  },
  {
    n: '3',
    icon: 'nugget',
    title: 'Draft, review & export',
    body: 'Review AI-generated content, apply compliant templates, and export a submission-ready proposal with forms and attachments.',
  },
];

const stats = [
  { value: `${formatUsd(PRICE_RANGE.low)}/mo`, label: 'Starting price' },
  { value: `${TRIAL_DAYS} days`, label: 'Free trial, no card' },
  { value: 'Federal · state · local', label: 'Solicitations supported' },
];

// Brands whose contracts GovHub proposal work has supported (owner-provided).
// Woodborne Solutions renders as a text wordmark until its logo is supplied.
const proofBrands = [
  { name: 'Lockheed Martin', logo: '/brand/logos/social-proof/lockheed-martin.png' },
  { name: 'Boeing', logo: '/brand/logos/social-proof/boeing.png' },
  { name: 'Raytheon', logo: '/brand/logos/social-proof/raytheon.png' },
  { name: 'SpaceX', logo: '/brand/logos/social-proof/spacex.png' },
  { name: 'BAE Systems', logo: '/brand/logos/social-proof/bae-systems.png' },
  { name: 'General Dynamics', logo: '/brand/logos/social-proof/general-dynamics.png' },
  { name: 'Sentinel Health', logo: '/brand/logos/social-proof/sentinel-health.png' },
  { name: 'Woodborne Solutions' },
  { name: 'Trident AI Solutions', logo: '/brand/logos/social-proof/trident-ai.png' },
  { name: 'Cardinality.ai', logo: '/brand/logos/social-proof/cardinality-ai.svg' },
];

const homeFaqs = faqsForPage('/');
---

<BaseLayout title={title} description={description}>
  <SchemaOrg
    type="SoftwareApplication"
    data={{
      name: 'GovHub',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      description,
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: PRICE_RANGE.currency,
        lowPrice: PRICE_RANGE.low,
        highPrice: PRICE_RANGE.high,
        offerCount: PRICE_RANGE.offerCount,
      },
    }}
  />

  <main class="container">
    <Hero
      eyebrow="AI proposal software for government contractors"
      title={PRIMARY_KEYWORD.h1}
      lede="Upload the RFP. GovHub finds every requirement, fills the forms, and drafts a compliant proposal that sounds like your firm — in minutes, not weekends."
      primaryHref={SIGNUP_URL}
      primaryLabel="Start free trial"
      secondaryHref="/solutions/compliance-matrix-generator/"
      secondaryLabel="Try the free compliance matrix tool →"
      art="/brand/page-graphics/home-hero-strike-gold.svg"
    />

    <SocialProofMarquee brands={proofBrands} />

    <section class="block">
      <h2>Everything a proposal shop does — without hiring one</h2>
      <p class="section-lede">
        Shredding, drafting, compliance checks, forms, and formatting — the work
        that used to take a proposal team, built into one tool.
      </p>
      <FeatureGrid features={features} />
    </section>

    <section class="block">
      <h2>From RFP to a winning proposal in three steps</h2>
      <div class="gh-journey" aria-hidden="true"></div>
      <div class="steps">
        {steps.map((s) => (
          <div class="step">
            <div class="step-head">
              <span class="num">{s.n}</span>
              <Icon name={s.icon} size={26} />
            </div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="block">
      <h2>An end-to-end contract acquisition platform</h2>
      <p class="section-lede">
        From shredding the solicitation to a submission-ready package — GovHub
        covers the whole response.
      </p>
      <SolutionsGrid mode="featured" />
      <p class="more-link"><a href="/solutions/">See all solutions →</a></p>
    </section>

    <section class="block tool-teaser">
      <div class="teaser-card">
        <Icon name="pan" size={32} />
        <div>
          <h2>Try the free compliance matrix generator — right now</h2>
          <p>
            Paste an RFP and get a compliance matrix in seconds. It runs in your
            browser — no login, nothing is uploaded.
          </p>
        </div>
        <a class="teaser-cta" href="/solutions/compliance-matrix-generator/">Open the free tool</a>
      </div>
    </section>

    <section class="block audience">
      <h2>Built for your side of the table</h2>
      <ul>
        <li><a href="/for/small-business-contractors/">Small business contractors →</a></li>
        <li><a href="/for/system-integrators/">System integrators →</a></li>
      </ul>
    </section>

    <TrustSection />

    <Testimonials heading="What government contractors say" />

    {homeFaqs.length > 0 && (
      <FAQSchema faqs={homeFaqs} heading="Frequently asked questions" />
    )}

    <StatRow stats={stats} />

    <CTABand
      heading="Dig up your next contract."
      sub="14 days free, no card — your first proposal is ready before the trial ends."
      secondaryHref="/pricing/"
      secondaryLabel="See pricing"
    />
  </main>
</BaseLayout>

<style>
  main {
    padding: 0 1.5rem 2rem;
  }
  .block {
    margin: 4rem 0;
  }
  .block > h2 {
    margin: 0 0 0.5rem;
  }
  .section-lede {
    color: var(--fg-muted);
    max-width: 40rem;
    margin: 0 0 1rem;
    font-size: 1.05rem;
  }
  .steps {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    margin-top: 1.5rem;
  }
  .step {
    background: var(--bg-elevated);
    border: 1.5px solid var(--border);
    border-radius: var(--gh-radius-md);
    padding: 1.5rem;
    box-shadow: var(--shadow);
  }
  .step-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--gh-navy-600);
    color: #fff;
    font-family: var(--gh-font-brand);
    font-weight: 700;
  }
  .step h3 {
    margin: 0 0 0.4rem;
    font-size: 1.05rem;
  }
  .step p {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.95rem;
  }
  .more-link {
    margin-top: 1rem;
    font-weight: 600;
  }
  .audience ul {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin: 0.5rem 0 0;
  }
  .audience a {
    font-weight: 600;
  }
  .teaser-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    background: var(--gh-tint-sun);
    border: 1.5px solid var(--border);
    border-radius: var(--gh-radius-md);
    padding: 1.75rem 2rem;
  }
  .teaser-card div {
    flex: 1;
    min-width: 16rem;
  }
  .teaser-card h2 {
    margin: 0 0 0.4rem;
    font-size: 1.35rem;
  }
  .teaser-card p {
    margin: 0;
    color: var(--fg-muted);
  }
  .teaser-cta {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    background: var(--gh-maroon-600);
    color: #fff;
    border-radius: var(--gh-radius-pill);
    font-family: var(--gh-font-brand);
    font-weight: 600;
    white-space: nowrap;
    transition: background var(--gh-dur-fast) var(--gh-ease), transform var(--gh-dur-fast) var(--gh-ease);
  }
  .teaser-cta:hover {
    background: var(--gh-maroon-700);
    transform: translateY(-1px);
    text-decoration: none;
  }
</style>
