---
import BaseLayout from './BaseLayout.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  author: string;
  slug: string;
  pillarSlug?: string;
  cover?: string;
  coverAlt?: string;
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  author,
  slug,
  cover = '/brand/page-graphics/blog-trail-map.svg',
  coverAlt = '',
} = Astro.props;
const url = new URL(`/blog/${slug}/`, Astro.site).toString();
// Article's `image` is a required field for Google's rich-results validator.
// Post covers are decorative SVGs; the site default OG image is the
// guaranteed-present raster asset at the recommended 1200x630 size.
const schemaImage = new URL('/brand/social/og-default-1200x630.png', Astro.site).toString();
---

<BaseLayout title={title} description={description} canonical={url} ogType="article">
  <SchemaOrg
    type="Article"
    data={{
      headline: title,
      description,
      image: schemaImage,
      datePublished: publishDate.toISOString(),
      dateModified: (updatedDate ?? publishDate).toISOString(),
      author: { '@type': 'Person', name: author },
      mainEntityOfPage: url,
    }}
  />

  <main class="container">
    <Breadcrumbs
      items={[
        { name: 'Home', url: '/' },
        { name: 'Blog', url: '/blog/' },
        { name: title, url: `/blog/${slug}/` },
      ]}
    />

    <article class="prose post">
      <header>
        <h1>{title}</h1>
        <p class="byline">
          By {author} · <time datetime={publishDate.toISOString()}>
            {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {updatedDate && (
            <>
              · Updated <time datetime={updatedDate.toISOString()}>
                {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </>
          )}
        </p>
        <img
          class="cover"
          src={cover}
          alt={coverAlt}
          aria-hidden={coverAlt ? undefined : 'true'}
          width="820"
          height="460"
          loading="eager"
          decoding="async"
        />
      </header>
      <slot />
    </article>
  </main>
</BaseLayout>

<style>
  .post {
    margin: 3rem auto;
  }
  .byline {
    color: var(--fg-muted);
    font-size: 0.95rem;
    margin: 0.5rem 0 1.5rem;
  }
  .cover {
    width: 100%;
    height: auto;
    margin: 0 0 2rem;
  }
  .post :global(.post-figure) {
    width: 100%;
    height: auto;
    margin: 1.75rem 0;
  }
</style>
