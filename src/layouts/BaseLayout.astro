---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
// Self-hosted Gold Country type (no render-blocking Google Fonts request).
// Fraunces needs full.css for the SOFT/WONK axes the brand guide pins.
import '@fontsource-variable/fraunces/full.css';
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/figtree';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'GovHub — AI proposal writing for government contractors. Draft, review, and submit federal, state, and local RFP responses faster.',
  canonical,
  ogImage = '/brand/social/og-default-1200x630.png',
  noindex = false,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const fullOgImage = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={fullOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <link rel="icon" type="image/svg+xml" href="/brand/logos/govhub-favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="stylesheet" href="/brand/tokens/tokens.css" />

    <SchemaOrg type="Organization" />
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    /* Gold Country palette — legacy var names remapped onto the brand tokens
       (loaded from /brand/tokens/tokens.css) so every scoped style keeps working. */
    --bg: var(--gh-oat);
    --bg-elevated: var(--gh-surface);
    --fg: var(--gh-ink-900);
    --fg-muted: var(--gh-ink-700);
    --accent: var(--gh-maroon-600);
    --accent-hover: var(--gh-maroon-700);
    --accent-soft: rgba(160, 58, 44, 0.08);
    --border: var(--gh-line);
    --shadow: var(--gh-shadow-card);
    --max-width: 72rem;
    --content-width: 42rem;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--fg);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  body {
    /* Fontsource variable families register with a " Variable" suffix, so
       re-point the token font vars here (body beats :root for inheritance). */
    --gh-font-display: 'Fraunces Variable', Georgia, serif;
    --gh-font-brand: 'Bricolage Grotesque Variable', 'Figtree Variable', sans-serif;
    --gh-font-body: 'Figtree Variable', -apple-system, 'Segoe UI', sans-serif;
    font-family: var(--gh-font-body);
  }

  a {
    color: var(--gh-teal-700);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  h1,
  h2,
  h3 {
    font-family: var(--gh-font-display);
    font-variation-settings: 'SOFT' 100, 'WONK' 0;
    font-weight: 600;
    color: var(--gh-ink-900);
    line-height: 1.15;
    letter-spacing: 0;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
  }
  h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  main {
    min-height: calc(100vh - 12rem);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .prose {
    max-width: var(--content-width);
  }

  .prose p {
    color: var(--fg-muted);
    font-size: 1.05rem;
  }

  code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.95em;
  }
</style>
